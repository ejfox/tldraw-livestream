{
  "name": "@tldraw-livestream/server",
  "version": "0.1.0",
  "description": "Server-side middleware for tldraw-livestream moderation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejfox/tldraw-livestream"
  },
  "keywords": ["tldraw", "livestream", "moderation", "websocket", "middleware"]
}
