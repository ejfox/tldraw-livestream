{
  "name": "tldraw-livestream",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/client && npm run build -w packages/server",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "tsc --noEmit --workspaces",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
